NODE_ENV=production
PORT=3001

DATABASE_URL="mysql://user:password@127.0.0.1:3306/spark_ai_analyzer"

JWT_SECRET="replace_with_a_random_string_at_least_32_chars"
JWT_EXPIRES_IN="7d"

# Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY="replace_with_32_bytes_base64_key"

IP_HASH_SALT="replace_with_a_random_string_at_least_16_chars"

CORS_ORIGIN="https://your-domain.com"

DEFAULT_ADMIN_USERNAME="admin"
DEFAULT_ADMIN_PASSWORD="change_me_now"

LOG_LEVEL="info"
